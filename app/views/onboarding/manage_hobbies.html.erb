<div class="max-w-lg mx-auto">
  <h1 class="text-4xl font-bold mb-4">What are you into (outside of code)?</h1>
  <p class="text-gray-600 mb-6">
    Add at least one hobby so you can meet people who share them.
  </p>

  <%= form_with url: user_hobbies_path, method: :post, class: "flex gap-2 mb-3" do %>
    <%= text_field_tag :name,
          nil,
          autofocus: true,
          autocomplete: "off",
          placeholder: "e.g. surfing",
          class: "border rounded px-3 py-2 flex-1" %>
    <%= submit_tag "Add",
          class: "bg-party-lavender text-gray-900 px-6 py-2 rounded hover:brightness-95" %>
  <% end %>

  <% if @event_presenter %>
    <p class="mb-8">
      <%= link_to "See who else shares your interests!",
            event_path(@event_presenter.event),
            class: "text-sm text-party-cyan hover:opacity-80" %>
    </p>
  <% end %>

  <% if @user_hobby_presenters.any? %>
    <h2 class="text-xl font-semibold mb-3">Your hobbies</h2>
    <ul class="mb-8">
      <% @user_hobby_presenters.each do |user_hobby_presenter| %>
        <li class="flex items-center justify-between py-2 border-b">
          <span><%= user_hobby_presenter.hobby_name %></span>
          <%= button_to "Remove",
                user_hobby_path(user_hobby_presenter.user_hobby),
                method: :delete,
                class: "text-sm text-party-red hover:opacity-80" %>
        </li>
      <% end %>
    </ul>

    <%= link_to "Done — take me to the dashboard",
          dashboard_path,
          class: "bg-party-lavender text-gray-900 px-6 py-3 rounded hover:brightness-95 inline-block" %>
  <% end %>
</div>

<%# locals: (event_presenter:, attendable: false) %>
<li class="py-4 flex items-start justify-between gap-4">
  <%= link_to event_path(event_presenter.event), class: "group flex-1 min-w-0" do %>
    <h3 class="text-lg font-semibold group-hover:text-party-cyan">
      <%= event_presenter.name %>
    </h3>
    <p class="text-sm text-gray-600">
      <%= event_presenter.date_range %><br>
      <%= event_presenter.location %>
    </p>
  <% end %>

  <div class="shrink-0 flex flex-col items-end gap-1">
    <% if event_presenter.attended_by?(current_user) %>
      <%= render partial: "events/attendance_badge",
            locals: { presenter: event_presenter } %>
      <% if attendable %>
        <%= button_to "Cancel",
              event_attendance_path(event_presenter.event),
              method: :delete,
              class: "text-sm text-gray-500 hover:text-party-red" %>
      <% end %>
    <% elsif attendable %>
      <%= button_to "Attend",
            event_attendance_path(event_presenter.event),
            class: "bg-party-lavender text-gray-900 text-sm font-semibold px-4 py-2 rounded hover:brightness-95" %>
    <% end %>
  </div>
</li>

<%# locals: (event_presenter:) %>
<li class="py-4">
  <%= link_to event_path(event_presenter.event), class: "block group" do %>
    <div class="flex items-center justify-between gap-4">
      <h3 class="text-lg font-semibold group-hover:text-party-cyan">
        <%= event_presenter.name %>
      </h3>
      <% if event_presenter.attended_by?(current_user) %>
        <span class="inline-block whitespace-nowrap text-sm font-semibold text-party-green border border-party-green/40 rounded-full px-3 py-1">
          ✓ <%= event_presenter.attendance_statement %>
        </span>
      <% end %>
    </div>
    <p class="text-sm text-gray-600">
      <%= event_presenter.date_range %> · <%= event_presenter.location %>
    </p>
  <% end %>
</li>

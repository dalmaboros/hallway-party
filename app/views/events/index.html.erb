<div class="max-w-3xl mx-auto">
  <h1 class="text-3xl font-bold mb-6">Events</h1>

  <% if @event_presenters.any? %>
    <ul class="divide-y divide-gray-200">
      <% @event_presenters.each do |event_presenter| %>
        <li class="py-4">
          <%= link_to event_path(event_presenter), class: "block group" do %>
            <div class="flex items-baseline justify-between gap-4">
              <h2 class="text-lg font-semibold group-hover:text-party-cyan">
                <%= event_presenter.name %>
              </h2>
              <% if @current_user_event_ids.include?(event_presenter.id) %>
                <span class="text-xs uppercase tracking-wide text-party-green">
                  Attending
                </span>
              <% end %>
            </div>
            <p class="text-sm text-gray-600">
              <%= event_presenter.date_range %> · <%= event_presenter.location %>
            </p>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="text-center py-16 text-gray-600">
      No upcoming events yet.
    </div>
  <% end %>
</div>

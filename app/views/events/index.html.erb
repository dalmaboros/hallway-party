<div class="max-w-3xl mx-auto">
  <h1 class="text-3xl font-bold mb-6">Events</h1>

  <section id="upcoming-events" class="mb-10">
    <h2 class="text-xl font-semibold mb-3">Upcoming Events</h2>
    <% if @upcoming_event_presenters.any? %>
      <ul class="divide-y divide-gray-200">
        <%= render partial: "events/event_row",
              collection: @upcoming_event_presenters,
              as: :event_presenter %>
      </ul>
    <% else %>
      <p class="text-gray-600">No upcoming events yet.</p>
    <% end %>
  </section>

  <% if @past_event_presenters.any? %>
    <section id="past-events">
      <h2 class="text-xl font-semibold mb-3">Past Events</h2>
      <ul class="divide-y divide-gray-200">
        <%= render partial: "events/event_row",
              collection: @past_event_presenters,
              as: :event_presenter %>
      </ul>
    </section>
  <% end %>
</div>

<div class="max-w-3xl mx-auto">
  <header class="mb-8">
    <h1 class="text-3xl font-bold mb-2"><%= @event.name %></h1>
    <p class="text-gray-600 mb-1"><%= event_date_range(@event) %></p>
    <p class="text-gray-600 mb-2"><%= @event.location %></p>
    <% if @event.website.present? %>
      <%= link_to @event.website,
            @event.website,
            target: "_blank",
            rel: "noopener noreferrer",
            class: "inline-block text-party-cyan hover:opacity-80" %>
    <% end %>
  </header>

  <% if @viewer_is_attending %>
    <section>
      <h2 class="text-xl font-semibold mb-2">People here</h2>
      <p class="text-gray-600 mb-4">Ranked by shared interests.</p>

      <% if @attendees.any? %>
        <ul class="divide-y divide-gray-200">
          <%= render partial: "attendees/attendee",
                collection: @attendees,
                as: :attendee,
                locals: { current_user_hobby_ids: @current_user_hobby_ids } %>
        </ul>
      <% else %>
        <div class="text-center py-16 text-gray-600">
          You're early — check back when more folks have signed up.
        </div>
      <% end %>
    </section>
  <% end %>
</div>

<div class="max-w-3xl mx-auto">
  <header class="mb-8">
    <h1 class="text-3xl font-bold mb-2"><%= @event_presenter.name %></h1>

    <div class="event-badges">
      <% if @event_presenter.attended_by?(current_user) %>
        <div class="flex items-center gap-3 mb-2">
          <%= render partial: "events/attendance_badge",
                locals: { presenter: @event_presenter } %>
          <% if @event_presenter.attendable? %>
            <%= button_to "Cancel attendance",
                  event_attendance_path(@event_presenter.event),
                  method: :delete,
                  class: "text-sm text-gray-500 hover:text-party-red" %>
          <% end %>
        </div>
      <% end %>

      <% if @event_presenter.happening_today? %>
        <p class="inline-block text-sm font-semibold text-party-orchid bg-party-orchid-soft border border-party-orchid/40 rounded-full px-3 py-1 mb-2">
          Day <%= @event_presenter.current_day %> of <%= @event_presenter.total_days %>
        </p>
      <% elsif @event_presenter.upcoming? %>
        <p class="inline-block text-sm font-semibold text-party-orchid bg-party-orchid-soft border border-party-orchid/40 rounded-full px-3 py-1 mb-2">
          Starts in <%= pluralize(@event_presenter.days_until_start, "day") %>
        </p>
      <% end %>
    </div>

    <div class="event-details">
      <p class="text-gray-600 mb-1"><%= @event_presenter.date_range %> • <%= @event_presenter.location %></p>

      <% if @event_presenter.website %>
        <p>
          <%= link_to @event_presenter.website,
                @event_presenter.website,
                target: "_blank",
                rel: "noopener noreferrer",
                class: "inline-block text-party-cyan hover:opacity-80" %>
        </p>
      <% end %>
    </div>
  </header>

  <section class="event-attendees">
    <h2 class="text-xl font-semibold mb-4">
      <%= @event_presenter.happening_today? ? "People here" : "Attendees" %>
    </h2>

    <% if @event_presenter.attended_by?(current_user) %>
      <% if @matched_user_presenters.any? %>
        <section class="matched-attendees">
          <h3 class="text-lg font-semibold mb-2">People who share your interests</h3>
          <hr>
          <p class="text-gray-600 mt-1">Ranked by shared interests</p>
          <ul class="divide-y divide-gray-200 mb-8">
            <%= render partial: "attendees/attendee",
                  collection: @matched_user_presenters,
                  as: :presenter %>
          </ul>
        </section>
      <% end %>

      <% if @other_user_presenters.any? %>
        <section class="unmatched-attendees">
          <h3 class="text-lg font-semibold mb-2">Everyone else</h3>
          <hr>
          <ul class="divide-y divide-gray-200">
            <%= render partial: "attendees/attendee",
                  collection: @other_user_presenters,
                  as: :presenter %>
          </ul>
        </section>
      <% end %>

      <% if @matched_user_presenters.none? && @other_user_presenters.none? %>
        <div class="text-center py-1 text-gray-600">
          You're early — check back when more folks have signed up. :)
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-1 text-gray-600">
        You can see the conference attendees only if you are attending as well!
        <% if @event_presenter.attendable? %>
          <div class="mt-6">
            <%= button_to "I am attending!",
                  event_attendance_path(@event_presenter.event),
                  form_class: "inline-block",
                  class: "bg-party-lavender text-gray-900 text-sm font-semibold px-4 py-2 rounded hover:brightness-95" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </section> <!-- end attendees section -->
</div>

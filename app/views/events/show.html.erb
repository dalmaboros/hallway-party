<div class="max-w-3xl mx-auto">
  <header class="mb-8">
    <h1 class="text-3xl font-bold mb-2"><%= @event_presenter.name %></h1>
    <p class="text-gray-600 mb-1"><%= @event_presenter.date_range %></p>
    <% if @event_presenter.happening_today? %>
      <p class="inline-block text-sm font-semibold text-party-green border border-party-green/40 rounded-full px-3 py-1 mb-2">
        Day <%= @event_presenter.current_day %> of <%= @event_presenter.total_days %>
      </p>
    <% end %>
    <p class="text-gray-600 mb-2"><%= @event_presenter.location %></p>
    <% if @event_presenter.website %>
      <%= link_to @event_presenter.website,
            @event_presenter.website,
            target: "_blank",
            rel: "noopener noreferrer",
            class: "inline-block text-party-cyan hover:opacity-80" %>
    <% end %>
  </header>

  <% if @event_presenter.attended_by?(current_user) %>
    <section>
      <h2 class="text-xl font-semibold mb-2">People here</h2>
      <p class="text-gray-600 mb-4">Ranked by shared interests.</p>

      <% if @user_presenters.any? %>
        <ul class="divide-y divide-gray-200">
          <%= render partial: "attendees/attendee",
                collection: @user_presenters,
                as: :presenter %>
        </ul>
      <% else %>
        <div class="text-center py-16 text-gray-600">
          You're early — check back when more folks have signed up. :)
        </div>
      <% end %>
    </section>
  <% end %>
</div>

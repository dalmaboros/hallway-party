<div class="max-w-3xl mx-auto">
  <%= link_to "← Back to people at #{@event.name}",
        event_attendees_path(@event),
        class: "inline-block text-sm text-gray-500 hover:text-gray-700 mb-4" %>

  <h1 class="text-3xl font-bold mb-2">
    People at <%= @event.name %> who like <%= @hobby.name %>
  </h1>
  <p class="text-gray-600 mb-8">
    <%= pluralize(@attendee_presenters.size, "other attendee") %>.
  </p>

  <% if @attendee_presenters.any? %>
    <ul class="divide-y divide-gray-200">
      <%= render partial: "attendees/attendee",
            collection: @attendee_presenters,
            as: :presenter,
            locals: { current_user_hobby_ids: @current_user_hobby_ids } %>
    </ul>
  <% else %>
    <div class="text-center py-16 text-gray-600">
      Nobody else here lists <%= @hobby.name %> yet — be the conversation-starter.
    </div>
  <% end %>
</div>

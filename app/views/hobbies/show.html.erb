<div class="max-w-3xl mx-auto">
  <h1 class="text-3xl font-bold mb-2">
    People who like <%= @hobby_presenter.name %>
  </h1>
  <p class="text-gray-600 mb-8">
    <%= pluralize(@user_presenters.size, "other person", "other people") %>.
  </p>

  <% if @user_presenters.any? %>
    <ul class="divide-y divide-gray-200">
      <%= render partial: "attendees/attendee",
            collection: @user_presenters,
            as: :presenter %>
    </ul>
  <% else %>
    <div class="text-center py-16 text-gray-600">
      Nobody else lists <%= @hobby_presenter.name %> yet — be the conversation-starter.
    </div>
  <% end %>
</div>

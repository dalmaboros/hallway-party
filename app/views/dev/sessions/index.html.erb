<div class="max-w-2xl mx-auto">
  <h1 class="text-3xl font-bold mb-2">Dev sign-in</h1>
  <p class="text-gray-600 mb-6">
    Quick sign-in for development. These users are seeded via
    <code class="text-sm bg-gray-100 px-1 rounded">db/seeds/users.rb</code>.
    Real GitHub OAuth still works at
    <code class="text-sm bg-gray-100 px-1 rounded">/auth/github</code>.
  </p>

  <% if user_signed_in? %>
    <div class="bg-amber-50 border border-amber-200 rounded p-3 mb-6 text-sm flex items-center justify-between">
      <span>Currently signed in as <strong>@<%= current_user.username %></strong></span>
      <%= button_to "Sign out", sign_out_path, method: :delete, class: "underline hover:no-underline" %>
    </div>
  <% end %>

  <ul class="grid grid-cols-2 gap-3">
    <% @users.each do |user| %>
      <li>
        <%= button_to dev_sign_in_as_path(username: user.username),
              method: :post,
              class: "w-full text-left p-3 rounded border border-gray-200 hover:border-party-cyan hover:bg-party-cyan-soft transition" do %>
          <div class="font-semibold"><%= user.name %></div>
          <div class="text-sm text-gray-600">@<%= user.username %></div>
        <% end %>
      </li>
    <% end %>
  </ul>
</div>

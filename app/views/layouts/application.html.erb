<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Hallway Party" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Hallway Party">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if Rails.env.development? %>
      <div class="bg-amber-100 text-amber-900 text-xs px-4 py-1 flex items-center justify-between">
        <span>
          Dev mode<% if user_signed_in? %> · Signed in as <strong>@<%= current_user.username %></strong><% end %>
        </span>
        <%= link_to "Switch user →", dev_sign_in_path, class: "underline hover:no-underline" %>
      </div>
    <% end %>

    <% if user_signed_in? %>
      <%= render partial: "layouts/navbar" %>
    <% end %>

    <main class="container mx-auto mt-12 px-5 flex flex-col">
      <!-- TODO: Make into a component? -->
      <% if flash[:notice] %>
        <div class="bg-party-green/10 border border-party-green/30 text-party-green px-4 py-3 rounded mb-4">
          <%= flash[:notice] %>
          <% if flash[:undo_attendance_path] %>
            (<%= link_to "oops, no I'm not", flash[:undo_attendance_path], data: { turbo_method: :delete }, class: "underline hover:opacity-80" %>)
          <% end %>
        </div>
      <% end %>

      <% if flash[:alert] %>
        <div class="bg-party-red/10 border border-party-red/30 text-party-red px-4 py-3 rounded mb-4">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>

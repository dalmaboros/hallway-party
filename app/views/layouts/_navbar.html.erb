<nav class="bg-white border-b border-gray-200">
  <div class="container mx-auto px-5 py-3 flex items-center justify-between gap-4">
    <%= link_to "🥳 hallway-party", dashboard_path, class: "font-bold text-lg" %>

    <div class="flex items-center gap-5">
      <%= link_to "Events", events_path, class: "text-gray-700 hover:text-party-cyan" %>

      <%# Layout chrome has no owning controller; constructing the presenter
          inline here is an explicit exception to the "presenters live in
          controllers" rule. Revisit if NavbarComponent is introduced. %>
      <% presenter = UserPresenter.new(current_user) %>
      <%= link_to profile_path(presenter.username), aria: { label: "Your profile" } do %>
        <%= render "users/avatar", presenter: presenter, size: :sm %>
      <% end %>

      <%= button_to "Sign out",
            sign_out_path,
            method: :delete,
            class: "text-sm text-gray-600 hover:text-gray-900" %>
    </div>
  </div>
</nav>

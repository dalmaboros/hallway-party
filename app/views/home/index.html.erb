<div class="flex items-center justify-center min-h-[70vh]">
  <div class="text-center max-w-lg">
    <p class="text-5xl mb-8">🥳</p>
    <p class="text-3xl mb-4">Turn the hallway track into a</p>
    <h1 class="text-6xl font-bold mb-6">hallway party</h1>
    <p class="text-3xl mb-8">
      Meet Rubyists at conferences based on shared
      <span class="gradient-text font-bold">hobbies and interests</span>.
    </p>

    <% if user_signed_in? %>
      <p class="mb-4">Welcome back, <%= current_user.name %>!</p>
      <%= link_to "Go to dashboard",
            "/dashboard",
            class: "inline-block px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700" %>
    <% else %>
      <div data-controller="confetti" class="fixed inset-0 pointer-events-none -z-10" aria-hidden="true"></div>
      <%= button_to "Sign in with GitHub",
            "/auth/github",
            method: :post,
            data: { turbo: false },
            class: "inline-block px-6 py-3 bg-gray-900 text-white text-lg rounded-lg hover:bg-gray-800" %>
    <% end %>
  </div>
</div>

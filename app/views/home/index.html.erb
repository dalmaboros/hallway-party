<div class="flex items-center justify-center min-h-[70vh]">
  <div class="text-center max-w-lg">
    <h1 class="text-5xl font-bold mb-4">Hallway Party</h1>
    <p class="text-lg text-gray-600 mb-8">
      Meet Rubyists at conferences based on shared hobbies and interests.
    </p>

    <% if user_signed_in? %>
      <p class="mb-4">Welcome back, <%= current_user.name %>!</p>
      <%= link_to "Go to dashboard", "/dashboard", class: "inline-block px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700" %>
    <% else %>
      <%= button_to "Sign in with GitHub",
            "/auth/github",
            method: :post,
            data: { turbo: false },
            class: "inline-block px-6 py-3 bg-gray-900 text-white rounded-lg hover:bg-gray-800" %>
    <% end %>
  </div>
</div>

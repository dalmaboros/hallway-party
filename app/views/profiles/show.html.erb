<div class="max-w-2xl mx-auto">
  <header class="flex gap-4 mb-6">
    <%= render partial: "users/avatar", locals: { presenter: @user_presenter, size: :lg } %>
    <div class="flex-1">
      <h1 class="text-3xl font-bold">
        <%= @user_presenter.name %>
        <% if @user_presenter.pronouns.present? %>
          <span class="text-base font-normal text-gray-500">(<%= @user_presenter.pronouns %>)</span>
        <% end %>
      </h1>
      <% if @user_presenter.location.present? %>
        <div class="text-sm text-gray-500 mt-1"><%= @user_presenter.location %></div>
      <% end %>
      <div class="flex gap-3 mt-2 text-gray-500">
        <%= link_to "https://github.com/#{@user_presenter.username}",
              target: "_blank",
              rel: "noopener noreferrer",
              class: "hover:text-party-cyan",
              aria: { label: "GitHub" } do %>
          <%= render partial: "icons/github" %>
        <% end %>
        <% if @user_presenter.twitter_url.present? %>
          <%= link_to @user_presenter.twitter_url,
                target: "_blank",
                rel: "noopener noreferrer",
                class: "hover:text-party-cyan",
                aria: { label: "Twitter" } do %>
            <%= render partial: "icons/twitter" %>
          <% end %>
        <% end %>
        <% if @user_presenter.website.present? %>
          <%= link_to @user_presenter.website,
                target: "_blank",
                rel: "noopener noreferrer",
                class: "hover:text-party-cyan",
                aria: { label: "Website" } do %>
            <%= render partial: "icons/globe" %>
          <% end %>
        <% end %>
      </div>
    </div>
  </header>

  <% if @user_presenter.bio.present? %>
    <section class="mb-6">
      <p class="whitespace-pre-line"><%= @user_presenter.bio %></p>
    </section>
  <% end %>

  <% if @user_presenter.hobby_presenters.any? %>
    <% if @user_presenter.shared_hobby_presenters.any? %>
      <section class="mb-6">
        <h2 class="text-sm uppercase tracking-wide text-gray-500 mb-2">
          Shared with you
          <span class="text-gray-400">· <%= @user_presenter.shared_hobby_presenters.size %></span>
        </h2>
        <ul class="flex flex-wrap gap-2">
          <%= render partial: "hobbies/hobby_pill",
                collection: @user_presenter.shared_hobby_presenters,
                as: :presenter,
                locals: { shared: true } %>
        </ul>
      </section>
    <% end %>

    <% if @user_presenter.non_shared_hobby_presenters.any? %>
      <section class="mb-6">
        <h2 class="text-sm uppercase tracking-wide text-gray-500 mb-2">
          <%= @user_presenter.shared_hobby_presenters.any? ? "Also into" : "Hobbies" %>
        </h2>
        <ul class="flex flex-wrap gap-2">
          <%= render partial: "hobbies/hobby_pill",
                collection: @user_presenter.non_shared_hobby_presenters,
                as: :presenter,
                locals: { shared: false } %>
        </ul>
      </section>
    <% end %>
  <% else %>
    <section class="mb-6">
      <h2 class="text-sm uppercase tracking-wide text-gray-500 mb-2">Hobbies</h2>
      <p class="text-gray-500 text-sm">No hobbies listed yet.</p>
    </section>
  <% end %>

  <% if @user_presenter.not_past_events.any? %>
    <section class="mb-6">
      <h2 class="text-sm uppercase tracking-wide text-gray-500 mb-2">Attending</h2>
      <ul class="flex flex-wrap gap-2 text-sm">
        <% @user_presenter.not_past_events.each do |event| %>
          <li>
            <%= link_to event.name,
                  event_path(event),
                  class: "inline-block bg-gray-100 border border-gray-200 rounded-full px-3 py-1 transition hover:bg-gray-200" %>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <% if @user_presenter.past_events.any? %>
    <section class="mb-6">
      <h2 class="text-sm uppercase tracking-wide text-gray-500 mb-2">Past events</h2>
      <ul class="flex flex-wrap gap-2 text-sm">
        <% @user_presenter.past_events.each do |event| %>
          <li>
            <%= link_to event.name,
                  event_path(event),
                  class: "inline-block bg-gray-100 border border-gray-200 rounded-full px-3 py-1 text-gray-600 transition hover:bg-gray-200" %>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>
</div>

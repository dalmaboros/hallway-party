<div class="max-w-3xl mx-auto">
  <h1 class="text-3xl font-bold mb-2">People at <%= @event.name %></h1>
  <p class="text-gray-600 mb-8">Ranked by shared interests.</p>

  <% if @attendees.any? %>
    <ul class="divide-y divide-gray-200">
      <% @attendees.each do |attendee| %>
        <li class="py-4 flex gap-4">
          <% if attendee.avatar_url.present? %>
            <img src="<%= attendee.avatar_url %>" alt="" class="w-12 h-12 rounded-full flex-shrink-0">
          <% end %>
          <div class="flex-1">
            <div class="font-semibold"><%= attendee.name %></div>
            <div class="text-sm text-gray-500 mb-2">@<%= attendee.username %></div>
            <ul class="flex flex-wrap gap-2">
              <% attendee.hobbies.sort_by(&:name).each do |hobby| %>
                <li class="bg-gray-100 border border-gray-200 rounded-full px-3 py-1 text-xs">
                  <%= hobby.name %>
                </li>
              <% end %>
            </ul>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="text-center py-16 text-gray-600">
      You're early — check back when more folks have signed up.
    </div>
  <% end %>
</div>

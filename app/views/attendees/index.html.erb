<div class="max-w-3xl mx-auto">
  <h1 class="text-3xl font-bold mb-2">People at <%= @event_presenter.name %></h1>
  <p class="text-gray-600 mb-8">Ranked by shared interests.</p>

  <% if @attendee_presenters.any? %>
    <ul class="divide-y divide-gray-200">
      <%= render partial: "attendees/attendee",
            collection: @attendee_presenters,
            as: :presenter %>
    </ul>
  <% else %>
    <div class="text-center py-16 text-gray-600">
      You're early — check back when more folks have signed up.
    </div>
  <% end %>
</div>

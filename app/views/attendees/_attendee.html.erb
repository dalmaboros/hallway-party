<%# locals: (presenter:) %>
<li class="py-4 flex gap-4">
  <%= render "users/avatar", presenter: presenter, size: :md %>
  <div class="flex-1">
    <div class="font-semibold">
      <%= link_to presenter.name, profile_path(presenter.username), class: "hover:text-party-cyan" %>
    </div>
    <div class="text-sm text-gray-500 mb-2">@<%= presenter.username %></div>
    <ul class="flex flex-wrap gap-2">
      <% presenter.hobbies.sort_by(&:name).each do |hobby| %>
        <%= render "hobbies/hobby_pill",
              hobby: hobby,
              shared: current_user.has_hobby?(hobby) %>
      <% end %>
    </ul>
  </div>
</li>

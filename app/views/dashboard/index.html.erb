<div class="max-w-2xl mx-auto">
  <h1 class="text-3xl font-bold mb-4">Dashboard</h1>
  <p class="mb-4">
    Signed in as <strong><%= current_user.name %></strong>
    (<%= current_user.username %>).
  </p>

  <section class="mb-6">
    <div class="flex items-baseline justify-between mb-2">
      <h2 class="text-xl font-semibold">Your hobbies</h2>
      <%= link_to "Edit", onboarding_hobbies_path, class: "text-sm text-party-cyan hover:opacity-80" %>
    </div>
    <ul class="flex flex-wrap gap-2">
      <% @hobbies.each do |hobby| %>
        <li class="bg-gray-100 border border-gray-200 rounded-full px-3 py-1 text-sm transition hover:text-white hover:border-transparent <%= hobby_pill_theme(hobby)[:hover] %>">
          <%= hobby.name %>
        </li>
      <% end %>
    </ul>
  </section>

  <% current_event = current_user.events.active.first %>
  <% if current_event %>
    <section class="mb-6">
      <%= link_to "See who else is at #{current_event.name}",
            event_attendees_path(current_event),
            class: "inline-block bg-party-lavender text-gray-900 px-6 py-3 rounded hover:brightness-95" %>
    </section>
  <% end %>

  <%= button_to "Sign out",
        sign_out_path,
        method: :delete,
        class: "px-4 py-2 bg-gray-200 rounded hover:bg-gray-300" %>
</div>

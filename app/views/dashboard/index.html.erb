<div class="max-w-2xl mx-auto">
  <h1 class="text-3xl font-bold mb-4">Dashboard</h1>
  <p class="mb-4">
    Signed in as <strong><%= current_user.name %></strong>
    (<%= current_user.username %>).
  </p>

  <%= button_to "Sign out",
        sign_out_path,
        method: :delete,
        class: "px-4 py-2 bg-gray-200 rounded hover:bg-gray-300" %>
</div>

<div class="max-w-2xl mx-auto">
  <h1 class="text-3xl font-bold mb-4">Dashboard</h1>
  <p class="mb-4">
    Signed in as <strong><%= @user_presenter.name %></strong>
    (<%= @user_presenter.username %>).
  </p>

  <section class="mb-6">
    <div class="flex items-baseline justify-between mb-2">
      <h2 class="text-xl font-semibold">Your hobbies</h2>
      <%= link_to "Edit", onboarding_hobbies_path, class: "text-sm text-party-cyan hover:opacity-80" %>
    </div>
    <ul class="flex flex-wrap gap-2">
      <% @hobbies.each do |hobby| %>
        <%= render "hobbies/hobby_pill", hobby: hobby %>
      <% end %>
    </ul>
  </section>

  <% if @current_event_presenter %>
    <section class="mb-6">
      <% if @current_event_presenter.current_day %>
        <p class="inline-block text-sm font-semibold text-party-green border border-party-green/40 rounded-full px-3 py-1 mb-3">
          Day <%= @current_event_presenter.current_day %> of <%= @current_event_presenter.total_days %>
        </p>
      <% end %>
      <%= link_to "See who else is at #{@current_event_presenter.name}",
            event_attendees_path(@current_event_presenter),
            class: "inline-block bg-party-lavender text-gray-900 px-6 py-3 rounded hover:brightness-95" %>
    </section>
  <% end %>
</div>

<div class="max-w-2xl mx-auto">
  <h1 class="text-3xl font-bold mb-4">Dashboard</h1>
  <p class="mb-4">
    Signed in as <strong><%= @user_presenter.name %></strong>
    (<%= @user_presenter.username %>).
  </p>

  <section class="mb-6">
    <div class="flex items-baseline justify-between mb-2">
      <h2 class="text-xl font-semibold">Your hobbies</h2>
      <%= link_to "Edit", onboarding_hobbies_path, class: "text-sm text-party-cyan hover:opacity-80" %>
    </div>
    <ul class="flex flex-wrap gap-2">
      <%= render partial: "hobbies/hobby_pill",
            collection: @hobby_presenters,
            as: :presenter %>
    </ul>
  </section>

  <% if @event_presenter %>
    <section class="mb-6">
      <% if @event_presenter.happening_today? %>
        <p class="inline-block text-sm font-semibold text-party-green border border-party-green/40 rounded-full px-3 py-1 mb-3">
          Day <%= @event_presenter.current_day %> of <%= @event_presenter.total_days %>
        </p>
      <% end %>
      <%= link_to "See who else is at #{@event_presenter.name}",
            event_path(@event_presenter),
            class: "inline-block bg-party-lavender text-gray-900 px-6 py-3 rounded hover:brightness-95" %>
    </section>
  <% end %>

  <% if @user_presenter.past_events.any? %>
    <section class="mb-6">
      <h2 class="text-sm uppercase tracking-wide text-gray-500 mb-2">Past events</h2>
      <ul class="flex flex-wrap gap-2 text-sm">
        <% @user_presenter.past_events.each do |past_event| %>
          <li>
            <%= link_to past_event.name,
                  event_path(past_event),
                  class: "inline-block bg-gray-100 border border-gray-200 rounded-full px-3 py-1 text-gray-600 transition hover:bg-gray-200" %>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>
</div>

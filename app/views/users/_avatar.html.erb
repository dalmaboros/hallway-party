<%# locals: (user:, size: :lg) %>
<% sizes = avatar_size_classes(size) %>
<% if user.avatar_url.present? %>
  <%= image_tag user.avatar_url, alt: "", class: "#{sizes[:box]} rounded-full shrink-0" %>
<% else %>
  <div class="<%= sizes[:box] %> rounded-full shrink-0 flex items-center justify-center text-white font-semibold <%= sizes[:text] %> <%= avatar_color_class(user) %>"
       aria-hidden="true">
    <%= user_initials(user) %>
  </div>
<% end %>

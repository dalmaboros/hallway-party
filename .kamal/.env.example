# Copy this file to .kamal/.env (gitignored) and fill in values from your password manager.
# Source: 1Password / iCloud Keychain / wherever you stored these during setup.

# GitHub Personal Access Token with `write:packages` scope (for ghcr.io)
export KAMAL_REGISTRY_PASSWORD="ghp_..."

# Supabase Session Pooler — port 5432 (Transaction Pooler at 6543 won't work for Rails)
export DB_HOST="aws-1-eu-central-1.pooler.supabase.com"
export DB_PORT="5432"
export DB_USERNAME="postgres.fxmoidgxpfhalywnjtry"
export DB_PASSWORD="..."  # the Supabase project password you set during project creation

# GitHub OAuth app credentials — github.com/settings/developers
# Make sure the production callback URL `https://hallway.party/auth/github/callback` is registered
export GITHUB_CLIENT_ID="..."
export GITHUB_CLIENT_SECRET="..."

# OpenAI API key — platform.openai.com/api-keys
export OPENAI_API_KEY="sk-..."

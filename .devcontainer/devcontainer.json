// For format details, see https://containers.dev/implementors/json_reference/.
{
  "name": "hallway-party",
  "dockerComposeFile": "compose.yaml",
  "service": "rails-app",
  "workspaceFolder": "/workspaces/hallway-party",

  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/rails/devcontainer/features/activestorage": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": { "moby": false }
  },

  "containerEnv": {
    "KAMAL_REGISTRY_PASSWORD": "$KAMAL_REGISTRY_PASSWORD"
  },

  "forwardPorts": [3000],

  // bin/setup must use --skip-server here — otherwise it execs bin/dev and
  // postCreateCommand never returns.
  "postCreateCommand": "bin/setup --skip-server"
}
